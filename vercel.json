{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/followup",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/summary",
      "schedule": "0 15 * * *"
    },

    { "path": "/api/keepalive", 
      "schedule": "*/4 * * * *" }
  ]
}
